{
  "_comments": {
    "comment1": "Inverted flag mirrors angle within [min,max] range for paired L/R servos. Init angle comes from global calibrate_angle (calibrate_on_init)."
  },
  "global": {
    "calibrate_on_init": true,
    "calibrate_angle": 90
  },
  "idle": {
    "_comment": "Brain idle behaviour: blink and random gaze. eyes_closed angles come from expressions.eyes_closed.",
    "interval_min": 2.0,
    "interval_max": 6.0,
    "blink_chance": 0.5,
    "blink_close_min": 0.04,
    "blink_close_max": 0.08,
    "blink_hold_min": 0.06,
    "blink_hold_max": 0.15,
    "blink_open_min": 0.04,
    "blink_open_max": 0.10,
    "gaze_extent_fraction": 0.75,
    "gaze_extent_x": 32,
    "gaze_extent_y": 12,
    "gaze_hold_min": 1.5,
    "gaze_hold_max": 3.5,
    "gaze_move_duration": 0.25,
    "gaze_return_duration": 0.3
  },
  "servos": {
    "EyeLidLeftDown": {
      "pin": 15,
      "wire_colors": ["red", "green", "green"],
      "min_angle": 55,
      "max_angle": 90,
      "inverted": false
    },
    "EyeLidLeftUp": {
      "pin": 14,
      "wire_colors": ["green", "red", "green"],
      "min_angle": 120,
      "max_angle": 165,
      "inverted": false
    },
    "EyeLidRightDown": {
      "pin": 12,
      "wire_colors": ["red", "green", "white"],
      "min_angle": 130,
      "max_angle": 170,
      "inverted": false
    },
    "EyeLidRightUp": {
      "pin": 11,
      "wire_colors": ["green", "green", "green"],
      "min_angle": 100,
      "max_angle": 150,
      "inverted": false
    },
    "EyeYAxis": {
      "pin": 13,
      "wire_colors": ["green", "white", "white"],
      "min_angle": 75,
      "max_angle": 130,
      "inverted": false
    },
    "EyeXAxis": {
      "pin": 10,
      "wire_colors": ["white", "red", "white"],
      "min_angle": 80,
      "max_angle": 250,
      "inverted": false
    },
    "EyebrowInnerRight": {
      "pin": 6,
      "wire_colors": ["red", "red", "red"],
      "min_angle": 30,
      "max_angle": 200,
      "inverted": false
    },
    "EyebrowInnerLeft": {
      "pin": 9,
      "wire_colors": ["white", "white", "red"],
      "min_angle": 0,
      "max_angle": 160,
      "inverted": false
    },
    "EyebrowOuterRight": {
      "pin": 7,
      "wire_colors": ["white", "white", "white"],
      "min_angle": 70,
      "max_angle": 260,
      "inverted": false
    },
    "EyebrowOuterLeft": {
      "pin": 8,
      "wire_colors": ["green", "white", "green"],
      "min_angle": 80,
      "max_angle": 250,
      "inverted": false
    },
    "RightCheekUp": {
      "pin": 2,
      "wire_colors": ["red", "white", "red"],
      "min_angle": 240,
      "max_angle": 310,
      "inverted": false
    },
    "RightCheekDown": {
      "pin": 1,
      "wire_colors": ["red", "green", "red"],
      "min_angle": 10,
      "max_angle": 160,
      "inverted": false
    },
    "LeftCheekUp": {
      "pin": 5,
      "wire_colors": ["green", "white", "white"],
      "min_angle": 0,
      "max_angle": 80,
      "inverted": false
    },
    "LeftCheekDown": {
      "pin": 4,
      "wire_colors": ["white", "red", "red"],
      "min_angle": 110,
      "max_angle": 360,
      "inverted": false
    },
    "RightJaw": {
      "pin": 3,
      "wire_colors": ["unk", "unk", "unk"],
      "min_angle": 0,
      "max_angle": 70,
      "inverted": false
    },
    "LeftJaw": {
      "pin": 0,
      "wire_colors": ["unk", "unk", "unk"],
      "min_angle": 110,
      "max_angle": 180,
      "inverted": false
    },
    "UpperLip": {
      "driver": "gpio",
      "pin": 27,
      "wire_colors": ["unk", "unk", "unk"],
      "min_angle": 0,
      "max_angle": 360,
      "inverted": false
    },
    "NeckYaw": {
      "driver": "gpio",
      "pin": 26,
      "wire_colors": ["unk", "unk", "unk"],
      "min_angle": 0,
      "max_angle": 360,
      "neutral_angle": 180,
      "inverted": false
    },
    "NeckPitch": {
      "driver": "gpio",
      "pin": 25,
      "wire_colors": ["unk", "unk", "unk"],
      "min_angle": 160,
      "max_angle": 230,
      "neutral_angle": 200,
      "inverted": false
    }
  },
  "lip_sync": {
    "enabled": true,
    "transition_duration": 0.05,
    "jaw_closed": {"LeftJaw": 110, "RightJaw": 70},
    "jaw_open": {"LeftJaw": 152, "RightJaw": 28},
    "upper_lip_neutral": 90,
    "upper_lip_raised": 120,
    "visemes": {
      "CLOSED": {"jaw_openness": 0.0, "lip_raise": 0.0},
      "SMALL":  {"jaw_openness": 0.15, "lip_raise": 0.0},
      "MEDIUM": {"jaw_openness": 0.4, "lip_raise": 0.0},
      "WIDE":   {"jaw_openness": 0.65, "lip_raise": 0.0},
      "ROUND":  {"jaw_openness": 0.35, "lip_raise": 0.3},
      "FV":     {"jaw_openness": 0.1, "lip_raise": 0.7}
    }
  },
  "expressions": {
    "neutral": {
      "EyeLidLeftDown": 90,
      "EyeLidLeftUp": 120,
      "EyeLidRightDown": 170,
      "EyeLidRightUp": 100,
      "EyeYAxis": 120,
      "EyeXAxis": 170,
      "EyebrowInnerRight": 170,
      "EyebrowInnerLeft": 30,
      "EyebrowOuterRight": 160,
      "EyebrowOuterLeft": 180,
      "LeftCheekUp": 60,
      "LeftCheekDown": 110,
      "RightCheekUp": 270,
      "RightCheekDown": 110,
      "LeftJaw": 110,
      "RightJaw": 70,
      "NeckYaw": 180,
      "NeckPitch": 200
    },
    "listening": {
      "EyeLidLeftDown": 90,
      "EyeLidLeftUp": 120,
      "EyeLidRightDown": 170,
      "EyeLidRightUp": 100,
      "EyeYAxis": 120,
      "EyeXAxis": 170,
      "EyebrowInnerRight": 200,
      "NeckYaw": 180,
      "NeckPitch": 200
    },
    "thinking": {
      "EyeLidLeftDown": 90,
      "EyeLidLeftUp": 120,
      "EyeLidRightDown": 170,
      "EyeLidRightUp": 100,
      "EyeYAxis": 120,
      "EyeXAxis": 170,
      "NeckYaw": 180,
      "NeckPitch": 200
    },
    "speaking": {
      "EyeLidLeftDown": 90,
      "EyeLidLeftUp": 120,
      "EyeLidRightDown": 170,
      "EyeLidRightUp": 100,
      "EyeYAxis": 120,
      "EyeXAxis": 170,
      "NeckYaw": 180,
      "NeckPitch": 200
    },
    "eyes_open": {
      "EyeLidLeftDown": 90,
      "EyeLidLeftUp": 120,
      "EyeLidRightDown": 170,
      "EyeLidRightUp": 100
    },
    "eyes_closed": {
      "EyeLidLeftDown": 55,
      "EyeLidLeftUp": 165,
      "EyeLidRightDown": 130,
      "EyeLidRightUp": 150
    }
  }
}
